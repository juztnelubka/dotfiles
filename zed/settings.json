// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "dock": "left",
    // M/A/D/U letter badges next to changed files (folders still tint)
    "git_status_indicator": true,
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "terminal": {
    "shell": {
      "program": "fish",
    },
  },
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "JetBrains",
  // option-click / option-drag = add cursors / column select
  "multi_cursor_modifier": "alt",
  // JetBrains-style autosave: save on focus/window switch
  "autosave": "on_focus_change",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Vesper",
  },
  // auto-install on any synced machine
  "auto_install_extensions": {
    "vesper": true,
    "basedpyright": true,
  },
  // hide from project panel + search
  "file_scan_exclusions": [
    "**/__pycache__",
    "**/*.pyc",
    "**/.idea",
    "**/.svelte-kit",
    "**/node_modules",
    "**/.DS_Store",
  ],
  // python type checker; venv/interpreter auto-detected per project
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright": {
          "analysis": {
            "typeCheckingMode": "standard",
            "diagnosticMode": "openFilesOnly",
            "useLibraryCodeForTypes": true,
          },
        },
      },
    },
  },
}
